<?xml version="1.0" encoding="utf-8"?>
<!-- No cloud backup and no device transfer: settings are trivial to redo and
     this app touches calls and SMS, so keep its data on the device. -->
<data-extraction-rules>
    <cloud-backup>
        <exclude domain="sharedpref" path="." />
    </cloud-backup>
    <device-transfer>
        <exclude domain="sharedpref" path="." />
    </device-transfer>
</data-extraction-rules>
